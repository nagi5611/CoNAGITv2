{
  "name": "conagitv2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CoNAGITv2 — 社内向けストレージ共有（Cloudflare Workers + D1、AWS S3/CloudFront）",
  "scripts": {
    "dev": "wrangler dev",
    "web:dev": "vite dev --config web/vite.config.mts",
    "web:build": "vite build --config web/vite.config.mts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e:local": "playwright test",
    "build": "wrangler deploy --dry-run && vite build --config web/vite.config.mts",
    "deploy": "wrangler deploy"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@cloudflare/workers-types": "^4.20250510.0",
    "@playwright/test": "^1.55.1",
    "@types/node": "^22.15.0",
    "eslint": "^9.26.0",
    "globals": "^17.6.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.14.4"
  }
}
