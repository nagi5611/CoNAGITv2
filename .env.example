# コピーして `.dev.vars` にリネームして使用（コミット禁止）
# https://developers.cloudflare.com/workers/wrangler/configuration/#secrets
#
# Worker の型定義は src/env.ts。ここに無いバインディング例: DB（D1）, THUMBNAIL_QUEUE（Queues producer）

# --- 認証・セッション ---
# ADMIN_INITIAL_USER=
# ADMIN_INITIAL_PASSWORD=
# SESSION_MAX_AGE_SECONDS=604800
# SESSION_SECRET=
# ENVIRONMENT=development

# --- 内部 Cron（ゴミ箱パージ） ---
# INTERNAL_CRON_SECRET=

# --- S3 / LocalStack（フェーズ G） ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=
# S3_ENDPOINT_HOST=127.0.0.1:4566
# S3_ENDPOINT_USE_HTTP=true

# プリサイン GET（プレビュー・ダウンロード URL）TTL（秒）。省略時 120、60〜900
# PRESIGN_GET_EXPIRES_SECONDS=120

# --- 任意: CDN キャッシュ無効化 Webhook ---
# CDN_INVALIDATION_WEBHOOK_URL=
# CDN_WEBHOOK_SECRET=

# --- フェーズ K: サムネジョブ ---
# 既定オン。0/false で thumbnail_jobs 行を挿入しない
# THUMBNAIL_JOBS_ENABLED=true

# 任意: Cloudflare Images List API の到達確認（サムネジョブの result_summary に追記、失敗でもジョブは継続）
# CF_ACCOUNT_ID=
# CF_IMAGES_API_TOKEN=

# CLOUDFRONT_* / 署名鍵は運用で管理（要件・フェーズ B,I）

# --- Playwright E2E（Worker では未使用・ローカル/CI のみ） ---
# E2E_BASE_URL=http://127.0.0.1:5173
